generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  VENDOR
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CertificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CertificationType {
  SUSTAINABILITY
  ORGANIC
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  COMPLETED
}

enum RentalAvailability {
  AVAILABLE
  UNAVAILABLE
  OCCUPIED
}

enum RentalBookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id                  String               @id @default(uuid())
  name                String
  email               String               @unique
  password            String
  role                UserRole             @default(CUSTOMER)
  status              UserStatus           @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  vendorProfile       VendorProfile?
  produces            Produce[]            @relation("VendorProduces")
  rentalSpaces        RentalSpace[]        @relation("VendorRentalSpaces")
  customerOrders      Order[]              @relation("CustomerOrders")
  vendorOrders        Order[]              @relation("VendorOrders")
  communityPosts      CommunityPost[]
  plantTrackings      PlantTracking[]
  sustainabilityCerts SustainabilityCert[] @relation("VendorSustainabilityCerts")
  reviewedCerts       SustainabilityCert[] @relation("AdminCertificationReviews")
  customerBookings    RentalBooking[]      @relation("CustomerRentalBookings")
  vendorBookings      RentalBooking[]      @relation("VendorRentalBookings")
}

model VendorProfile {
  id                  String              @id @default(uuid())
  userId              String              @unique
  farmName            String
  certificationStatus CertificationStatus @default(PENDING)
  farmLocation        String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([certificationStatus])
  @@index([farmLocation])
}

model Produce {
  id                  String              @id @default(uuid())
  vendorId            String
  name                String
  description         String
  price               Decimal             @db.Decimal(10, 2)
  category            String
  certificationStatus CertificationStatus @default(PENDING)
  availableQuantity   Int
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  vendor              User                @relation("VendorProduces", fields: [vendorId], references: [id], onDelete: Cascade)
  orders              Order[]

  @@index([vendorId])
  @@index([category])
  @@index([certificationStatus])
  @@index([name])
}

model RentalSpace {
  id           String             @id @default(uuid())
  vendorId     String
  location     String
  size         Float
  price        Decimal            @db.Decimal(10, 2)
  availability RentalAvailability @default(AVAILABLE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  vendor       User               @relation("VendorRentalSpaces", fields: [vendorId], references: [id], onDelete: Cascade)
  bookings     RentalBooking[]

  @@index([vendorId])
  @@index([availability])
  @@index([location])
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  produceId String
  vendorId  String
  quantity  Int
  unitPrice Decimal     @db.Decimal(10, 2)
  totalPrice Decimal    @db.Decimal(12, 2)
  status    OrderStatus @default(PENDING)
  orderDate DateTime    @default(now())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation("CustomerOrders", fields: [userId], references: [id], onDelete: Cascade)
  produce   Produce     @relation(fields: [produceId], references: [id], onDelete: Cascade)
  vendor    User        @relation("VendorOrders", fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([vendorId])
  @@index([produceId])
  @@index([status])
  @@index([orderDate])
  @@index([userId, status])
  @@index([vendorId, status])
}

model CommunityPost {
  id          String   @id @default(uuid())
  userId      String
  postContent String
  postDate    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postDate])
}

model SustainabilityCert {
  id                  String              @id @default(uuid())
  vendorId            String
  certificationType   CertificationType
  certifyingAgency    String
  certificationNumber String?
  certificationDate   DateTime
  documentUrl         String?
  status              CertificationStatus @default(PENDING)
  reviewNotes         String?
  reviewedAt          DateTime?
  reviewedById        String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  vendor              User                @relation("VendorSustainabilityCerts", fields: [vendorId], references: [id], onDelete: Cascade)
  reviewedBy          User?               @relation("AdminCertificationReviews", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([status])
  @@index([reviewedById])
  @@index([certificationDate])
}

model RentalBooking {
  id            String              @id @default(uuid())
  rentalSpaceId String
  customerId    String
  vendorId      String
  startDate     DateTime
  endDate       DateTime
  totalPrice    Decimal             @db.Decimal(10, 2)
  status        RentalBookingStatus @default(CONFIRMED)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  rentalSpace   RentalSpace         @relation(fields: [rentalSpaceId], references: [id], onDelete: Cascade)
  customer      User                @relation("CustomerRentalBookings", fields: [customerId], references: [id], onDelete: Cascade)
  vendor        User                @relation("VendorRentalBookings", fields: [vendorId], references: [id], onDelete: Cascade)
  plantTrackings PlantTracking[]

  @@index([rentalSpaceId])
  @@index([customerId])
  @@index([vendorId])
  @@index([status])
  @@index([startDate, endDate])
}

model PlantTracking {
  id                  String        @id @default(uuid())
  userId              String
  rentalBookingId     String?
  plantName           String
  growthStage         String
  healthStatus        String
  expectedHarvestDate DateTime?
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rentalBooking       RentalBooking? @relation(fields: [rentalBookingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([rentalBookingId])
  @@index([updatedAt])
  @@index([userId, updatedAt])
}
