NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/greengrid?schema=public"
JWT_SECRET="super_secret_change_me"
JWT_EXPIRES_IN="1d"
BCRYPT_SALT_ROUNDS=10
TRUST_PROXY=false
REQUEST_BODY_LIMIT="1mb"
RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=25
CERTIFICATION_RATE_LIMIT_MAX=10
FORUM_WRITE_RATE_LIMIT_MAX=40
PLANT_TRACKING_WRITE_RATE_LIMIT_MAX=60
SEED_DEFAULT_PASSWORD="Password@123"
BENCHMARK_BASE_URL="http://localhost:5000"
BENCHMARK_EMAIL="admin@greengrid.local"
BENCHMARK_PASSWORD="Password@123"
